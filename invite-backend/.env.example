# HTTP
PORT=8787
# Origin allowed to call /invite (the miniapp platform). Comma-separated allowed.
ALLOWED_ORIGIN=https://circles-dev.gnosis.io

# Gnosis Chain RPC used to send the inviter Safe's transactions.
RPC_URL=https://rpc.gnosischain.com

# The INVITER: a Safe that is a registered Circles human AND has invite quota on
# the InvitationFarm, with the invitation module enabled + trust set up.
# INVITER_PRIVATE_KEY is one of that Safe's owner keys (hot key — keep secret).
INVITER_SAFE_ADDRESS=
INVITER_PRIVATE_KEY=

# InvitationFarm contract on Gnosis. The SDK's bundled config ships 0x0, so the
# backend defaults to the known deployment; override here if redeployed.
INVITATION_FARM=0xd28b7C4f148B1F1E190840A1f7A796C5525D8902

# Per-IP rate limit for POST /invite. Each invite consumes farm quota, so these
# protect both the inviter's quota and the hot key.
RATE_WINDOW_MS=60000   # short window length (ms)
RATE_MAX=5             # max requests per short window per IP
RATE_DAILY_MAX=20      # max requests per 24h per IP

# Per-app signup attribution is written to this JSON file and served at GET /stats.
STATS_FILE=./data/stats.json
